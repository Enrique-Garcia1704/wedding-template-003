---

interface HeroData {
  nombreNovia: string;
  nombreNovio: string;
  fecha: string;
  lugar: string;
}

const { nombreNovia, nombreNovio, fecha, lugar } = Astro.props as HeroData;

// Convertir fecha UTC a hora de México
const fechaMX = fecha ? new Date(fecha).toLocaleString("es-MX", {
  timeZone: "America/Mexico_City",
  year: "numeric",
  month: "short",
  day: "numeric",
  hour: "2-digit",
  minute: "2-digit"
}) : "";

// Formatear fecha para mostrar solo hora
const horaMX = fecha ? new Date(fecha).toLocaleTimeString("es-MX", {
  timeZone: "America/Mexico_City",
  hour: "2-digit",
  minute: "2-digit",
  hour12: true
}) : "";
---

<section class="relative @container px-4 py-8 lg:px-40 lg:py-12" id="inicio">
  <div class="relative overflow-hidden rounded-xl lg:rounded-3xl min-h-[600px] flex flex-col items-center justify-center text-center p-6 spring-gradient border border-white/50 shadow-sm">
    <!-- Floral Accents -->
    <div class="absolute top-0 left-0 p-8 text-primary/20 select-none">
      <span class="material-symbols-outlined text-9xl">filter_vintage</span>
    </div>
    <div class="absolute bottom-0 right-0 p-8 text-primary/20 select-none">
      <span class="material-symbols-outlined text-9xl">filter_vintage</span>
    </div>
    
    <div class="z-10 flex flex-col gap-6 max-w-2xl">
      <span class="text-primary font-medium tracking-[0.2em] uppercase text-sm">¡Nos Casamos!</span>
      <h1 class="text-5xl lg:text-8xl font-bold text-slate-900 leading-tight">
        {nombreNovia} <span class="text-primary">&</span> {nombreNovio}
      </h1>
      <div class="h-px w-24 bg-primary/30 mx-auto my-2"></div>
      <div class="flex flex-col gap-2">
        <p class="text-xl lg:text-2xl font-display italic text-slate-700">{fechaMX}</p>
        <p class="text-base text-slate-600">{lugar} • {horaMX}</p>
      </div>
      <div class="mt-8">
        <a class="inline-flex h-14 items-center justify-center px-10 rounded-full bg-primary text-white text-lg font-bold shadow-xl shadow-primary/30 hover:scale-105 transition-transform" href="#rsvp">
          Confirmar Asistencia
        </a>
      </div>
    </div>
    
    <!-- Background pattern -->
    <div class="absolute inset-0 opacity-10 pointer-events-none" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuCjDsMV709zsIBdCWWbzZaQrq6uiWNe30GkYvAoQerIdkaQ66PrK4vUG71Z0fv6t-9g7wAe0p_5ySnBSEpfR5E0lEsaXzbt5jvPq9Wcs6u9UaCQyoLceu9ACNzUrrG5ajRsSXWPeEI6oF7lrYoKANnAekgQrAXFUeCNHFKjIDR1Q3OWT9lefpZby5P6D4HvS1OeevwZs1_sSEe9uKrp3ML3ZVhtGxGp5ADf9B8sk_tRwJa0nCa8plHGLDl7Y8zgzUeaiyXkBrgEho8');"></div>
  </div>
</section>
