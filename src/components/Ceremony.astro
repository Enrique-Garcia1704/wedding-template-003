---
interface HeroData {
  nombreNovia: string;
  nombreNovio: string;
  fecha: string;
  lugar: string;
  direccionMapa?: string;
  latitud?: number;
  longitud?: number;
  frase_principal: string;
  frase_secundaria: string;
  imagen_fondo: { url: string } | null;
}

const {
  nombreNovia,
  nombreNovio,
  fecha,
  lugar,
  direccionMapa,
  latitud,
  longitud,
  frase_principal,
  frase_secundaria,
  imagen_fondo
} = Astro.props as HeroData;

const fechaMX = fecha ? new Date(fecha).toLocaleString("es-MX", {
  timeZone: "America/Mexico_City",
  year: "numeric",
  month: "short",
  day: "numeric",
  hour: "2-digit",
  minute: "2-digit"
}) : "";

// Texto que se usará para búsqueda si no hay coordenadas
const ubicacionMapa = direccionMapa || lugar || "";

// URLs dinámicas
const mapaUrl =
  latitud != null && longitud != null
    ? `https://www.google.com/maps?q=${latitud},${longitud}&output=embed`
    : `https://www.google.com/maps?q=${encodeURIComponent(ubicacionMapa)}&output=embed`;

const googleMapsUrl =
  latitud != null && longitud != null
    ? `https://www.google.com/maps/search/?api=1&query=${latitud},${longitud}`
    : `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(ubicacionMapa)}`;
---

<section class="px-6 lg:px-40 py-20 bg-white dark:bg-slate-900/50" id="ceremomia">
  <div class="max-w-[960px] mx-auto">
    <div class="flex flex-col items-center mb-16 text-center">
      <span class="material-symbols-outlined text-4xl text-primary/40 mb-4">church</span>
      <h2 class="text-4xl font-bold font-display mb-4">La Ceremonia</h2>
      <p class="text-slate-600 max-w-lg">
        Un momento para compartir nuestro amor en un entorno primaveral rodeado de naturaleza.
      </p>
    </div>
    
    <div class="grid lg:grid-cols-2 gap-12 items-center bg-background-light dark:bg-background-dark rounded-3xl overflow-hidden border border-primary/5">
      <div class="h-full min-h-[400px]">
        <iframe
          src={mapaUrl}
          width="100%"
          height="100%"
          style="border:0;"
          loading="lazy"
          title="Ubicación del evento"
          aria-label={`Mapa con la ubicación de ${ubicacionMapa}`}
        ></iframe>
      </div>
      
      <div class="p-8 lg:p-12 flex flex-col gap-6">
        <div class="flex flex-col gap-1">
          <h3 class="text-2xl font-bold font-display text-primary">Nuestra Unión</h3>
          <p class="text-lg font-medium">{lugar}</p>
        </div>
        
        <div class="space-y-4">
          <div class="flex items-start gap-3">
            <span class="material-symbols-outlined text-primary">schedule</span>
            <p class="text-slate-600">{fechaMX}</p>
          </div>

          <div class="flex items-start gap-3">
            <span class="material-symbols-outlined text-primary">location_on</span>
            <p class="text-slate-600">{ubicacionMapa}</p>
          </div>
        </div>
        
        <div class="pt-4">
          <a
            href={googleMapsUrl}
            target="_blank"
            rel="noopener"
            class="w-full lg:w-auto px-8 py-3 rounded-xl border-2 border-primary text-primary font-bold hover:bg-primary hover:text-white transition-all flex items-center justify-center gap-2"
          >
            <span class="material-symbols-outlined text-sm">map</span>
            Ver en Google Maps
          </a>
        </div>
      </div>
    </div>
  </div>
</section>