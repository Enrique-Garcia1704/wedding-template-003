  <div class="petal" style="left: 30%; animation-delay: 2s;"></div>
  <div class="petal" style="left: 40%; animation-delay: 0.5s;"></div>
  <div class="petal" style="left: 50%; animation-delay: 1.5s;"></div>
  <div class="petal" style="left: 60%; animation-delay: 2.5s;"></div>
  <div class="petal" style="left: 70%; animation-delay: 0.8s;"></div>
  <div class="petal" style="left: 80%; animation-delay: 1.8s;"></div>
  <div class="petal" style="left: 90%; animation-delay: 2.8s;"></div>
  <div class="petal" style="left: 15%; animation-delay: 3s;"></div>
  <div class="petal" style="left: 25%; animation-delay: 3.5s;"></div>
  <div class="petal" style="left: 35%; animation-delay: 4s;"></div>
  <div class="petal" style="left: 45%; animation-delay: 4.5s;"></div>
  <div class="petal" style="left: 55%; animation-delay: 3.2s;"></div>
  <div class="petal" style="left: 65%; animation-delay: 3.7s;"></div>
